{{!< default}}

{{! Single post page }}

<article class="gh-article {{post_class}}">

  {{! Post header }}
  <header class="gh-article-header">
    <div class="gh-article-header-inner">

      {{! Tags }}
      {{#if tags}}
        <div class="gh-article-tags">
          {{#foreach tags}}
            <a class="gh-tag-pill" href="{{url}}">{{name}}</a>
          {{/foreach}}
        </div>
      {{/if}}

      <h1 class="gh-article-title">{{title}}</h1>

      {{#if excerpt}}
        <p class="gh-article-excerpt">{{excerpt}}</p>
      {{/if}}

      <div class="gh-article-meta">
        {{> "post-meta"}}
        {{#if @custom.show_reading_time}}
          <span class="gh-reading-time">{{reading_time}}</span>
        {{/if}}
      </div>

    </div>
  </header>

  {{! Audio player — reads metadata from codeinjection_head }}
  {{> "audio-player"}}

  {{! Hero image }}
  {{#if feature_image}}
    <figure class="gh-article-image">
      <img
        srcset="
          {{img_url feature_image size="s"}}  800w,
          {{img_url feature_image size="m"}} 1200w,
          {{img_url feature_image size="l"}} 1600w,
          {{img_url feature_image size="xl"}} 2400w
        "
        sizes="(min-width: 1200px) 1200px, 100vw"
        src="{{img_url feature_image size="m"}}"
        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        loading="eager"
      >
      {{#if feature_image_caption}}
        <figcaption>{{feature_image_caption}}</figcaption>
      {{/if}}
    </figure>
  {{/if}}

  {{! Post content }}
  <div class="gh-content gh-canvas">
    {{content}}
  </div>

  {{! Post footer }}
  <footer class="gh-article-footer gh-canvas">

    {{! Author bio }}
    {{#primary_author}}
      <div class="gh-author-box">
        {{#if profile_image}}
          <img class="gh-author-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
        {{/if}}
        <div class="gh-author-info">
          <a class="gh-author-name" href="{{url}}">{{name}}</a>
          {{#if bio}}
            <p class="gh-author-bio">{{bio}}</p>
          {{/if}}
        </div>
      </div>
    {{/primary_author}}

  </footer>

</article>

{{! Related posts }}
{{#get "posts" filter="tags:[{{tags.[0].slug}}]+id:-{{id}}" limit="3"}}
  {{#if posts}}
    <section class="gh-related gh-canvas">
      <h3 class="gh-related-title">More adventures</h3>
      <div class="gh-post-grid gh-post-grid-3">
        {{#foreach posts}}
          {{> "post-card"}}
        {{/foreach}}
      </div>
    </section>
  {{/if}}
{{/get}}
