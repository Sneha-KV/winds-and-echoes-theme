{{!
  partials/audio-player.hbs

  Renders the audio player for a post.
  Reads audio metadata from the post's codeinjection_head JSON block.

  Expected JSON in codeinjection_head:
  <script type="application/json" id="wae-audio">
  {
    "recordings": [
      { "mode": "narration", "label": "Listen to this post", "url": "https://...", "duration": 420 },
      { "mode": "ambient",   "label": "Summit ridge wind",   "url": "https://...", "duration": 180 }
    ],
    "audioFirst": false
  }
  </script>
}}

<div class="wae-audio-player" id="wae-audio-player" aria-label="Audio player" style="display:none">
  <div class="wae-audio-tabs" id="wae-audio-tabs"></div>
  <div class="wae-audio-controls">
    <button class="wae-play-btn" id="wae-play-btn" aria-label="Play">
      <svg class="wae-icon-play"  viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      <svg class="wae-icon-pause" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
    <div class="wae-progress-wrap">
      <div class="wae-progress-bar" id="wae-progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
        <div class="wae-progress-fill" id="wae-progress-fill"></div>
        <div class="wae-progress-thumb" id="wae-progress-thumb"></div>
      </div>
      <div class="wae-time-row">
        <span class="wae-time-current" id="wae-time-current">0:00</span>
        <span class="wae-track-label"  id="wae-track-label"></span>
        <span class="wae-time-total"   id="wae-time-total">0:00</span>
      </div>
    </div>
    <div class="wae-audio-actions">
      <button class="wae-speed-btn" id="wae-speed-btn" title="Playback speed">1×</button>
      <a class="wae-download-btn" id="wae-download-btn" download title="Download audio">↓</a>
    </div>
  </div>
</div>
