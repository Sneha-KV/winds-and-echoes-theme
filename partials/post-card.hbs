{{! Post card — used in homepage grid, tag pages, related posts }}

<article class="gh-card {{post_class}}">
  <a class="gh-card-link" href="{{url}}">

    {{! Feature image }}
    {{#if feature_image}}
      <div class="gh-card-image">
        <img
          srcset="
            {{img_url feature_image size="s"}}  800w,
            {{img_url feature_image size="m"}} 1200w
          "
          sizes="(min-width: 1000px) 400px, 100vw"
          src="{{img_url feature_image size="s"}}"
          alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
          loading="lazy"
        >
      </div>
    {{/if}}

    <div class="gh-card-content">

      {{! Primary tag }}
      {{#if primary_tag}}
        <span class="gh-card-tag">{{primary_tag.name}}</span>
      {{/if}}

      {{! Title }}
      <h2 class="gh-card-title">{{title}}</h2>

      {{! Excerpt }}
      {{#if excerpt}}
        <p class="gh-card-excerpt">{{excerpt words="20"}}</p>
      {{/if}}

      {{! Meta }}
      <div class="gh-card-meta">
        <span class="gh-card-date">{{date format="MMM D, YYYY"}}</span>
        {{#if @custom.show_reading_time}}
          <span class="gh-card-sep">·</span>
          <span class="gh-card-reading-time">{{reading_time}}</span>
        {{/if}}
      </div>

    </div>
  </a>
</article>
