{{! Site footer }}

<footer class="gh-foot">
  <div class="gh-foot-inner">

    <div class="gh-foot-brand">
      <a class="gh-foot-logo" href="{{@site.url}}">{{@site.title}}</a>
      {{#if @site.description}}
        <p class="gh-foot-tagline">{{@site.description}}</p>
      {{/if}}
    </div>

    <nav class="gh-foot-nav" aria-label="Footer navigation">
      {{navigation type="secondary"}}
    </nav>

    <div class="gh-foot-copy">
      <span>© {{date format="YYYY"}} {{@site.title}}</span>
      <span class="gh-foot-sep">·</span>
      <span>Published with <a href="https://ghost.org" target="_blank" rel="noreferrer">Ghost</a></span>
    </div>

  </div>
</footer>
