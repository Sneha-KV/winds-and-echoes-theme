{{!< default}}

<div class="gh-home">

  {{! Featured hero — first featured post }}
  {{#get "posts" filter="featured:true" limit="1"}}
    {{#foreach posts}}
      <section class="gh-hero">
        {{#if feature_image}}
          <div class="gh-hero-image">
            <img
              srcset="
                {{img_url feature_image size="m"}} 1200w,
                {{img_url feature_image size="l"}} 1600w
              "
              sizes="100vw"
              src="{{img_url feature_image size="m"}}"
              alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
              loading="eager"
            >
          </div>
        {{/if}}
        <div class="gh-hero-content">
          <div class="gh-hero-inner">
            {{#if primary_tag}}
              <div class="gh-hero-category">{{primary_tag.name}}</div>
            {{/if}}
            <h1 class="gh-hero-title">
              <a href="{{url}}">{{title}}</a>
            </h1>
            {{#if excerpt}}
              <p class="gh-hero-excerpt">{{excerpt words="30"}}</p>
            {{/if}}
            <div class="gh-hero-meta">
              {{#primary_author}}
                <div class="gh-hero-author">
                  {{#if profile_image}}
                    <img class="gh-hero-author-img" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                  {{/if}}
                  <span class="gh-hero-author-name">{{name}}</span>
                </div>
              {{/primary_author}}
              <span class="gh-hero-date">{{date format="MMM D, YYYY"}}</span>
              <a class="gh-hero-read" href="{{url}}">Read the story →</a>
            </div>
          </div>
        </div>
      </section>
    {{/foreach}}
  {{/get}}

  {{! Post feed }}
  <section class="gh-feed">
    <div class="gh-feed-inner">
      <div class="gh-section-label">
        <span class="gh-section-label-text">Latest adventures</span>
        <div class="gh-section-label-line"></div>
        <a class="gh-section-label-more" href="/adventures">View all →</a>
      </div>
      <div class="gh-post-grid">
        {{#foreach posts}}
          {{> "post-card"}}
        {{/foreach}}
      </div>
      {{pagination}}
    </div>
  </section>

</div>
