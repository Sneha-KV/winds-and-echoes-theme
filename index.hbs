{{!< default}}

{{! Homepage — shows featured post hero + post grid }}

<div class="gh-home">

  {{! Featured post hero — first featured post gets full-width treatment }}
  {{#get "posts" filter="featured:true" limit="1"}}
    {{#foreach posts}}
      <section class="gh-hero">
        {{#if feature_image}}
          <div class="gh-hero-image">
            <img
              srcset="
                {{img_url feature_image size="s"}} 800w,
                {{img_url feature_image size="m"}} 1200w,
                {{img_url feature_image size="l"}} 1600w
              "
              sizes="100vw"
              src="{{img_url feature_image size="m"}}"
              alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
              loading="eager"
            >
          </div>
        {{/if}}
        <div class="gh-hero-content">
          <div class="gh-hero-inner">
            {{#if primary_tag}}
              <a class="gh-hero-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            <h1 class="gh-hero-title">
              <a href="{{url}}">{{title}}</a>
            </h1>
            {{#if excerpt}}
              <p class="gh-hero-excerpt">{{excerpt words="30"}}</p>
            {{/if}}
            <div class="gh-hero-meta">
              {{> "post-meta"}}
            </div>
          </div>
        </div>
      </section>
    {{/foreach}}
  {{/get}}

  {{! Post grid }}
  <section class="gh-feed">
    <div class="gh-feed-inner">
      <h2 class="gh-feed-label">Latest adventures</h2>
      <div class="gh-post-grid">
        {{#foreach posts}}
          {{> "post-card"}}
        {{/foreach}}
      </div>

      {{! Pagination }}
      {{pagination}}
    </div>
  </section>

</div>
